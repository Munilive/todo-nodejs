{
  "$schema": "https://json.schemastore.org/nest-cli",
  "monorepo": true,
  "root": "api",
  "sourceRoot": "api/src",
  "entryFile": "main",
  "projects": {
    "api": {
      "type": "application",
      "root": "api",
      "sourceRoot": "api/src",
      "entryFile": "main",
      "compilerOptions": {
        "tsConfigPath": "api/tsconfig.json"
      }
    },
    "domain": {
      "type": "library",
      "root": "libs/domain",
      "entryFile": "index",
      "sourceRoot": "libs/domain/src",
      "compilerOptions": {
        "tsConfigPath": "libs/domain/tsconfig.lib.json"
      }
    }
  },
  "compilerOptions": {
    "builder": {
      "type": "swc"
    }
  }
}
