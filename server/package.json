{
  "name": "@todo-nodejs/server",
  "version": "0.0.1",
  "description": "Todo NestJS 모노레포 서버",
  "scripts": {
    "start:api": "node dist/api/main.js",
    "dev:api": "nest start api --watch",
    "build:api": "nest build api",
    "typecheck": "tsc -p api/tsconfig.json --noEmit",
    "test": "vitest run --config api/vitest.config.ts",
    "test:watch": "vitest --config api/vitest.config.ts",
    "test:coverage": "vitest run --coverage --config api/vitest.config.ts",
    "migration:create": "mikro-orm --config api/mikro-orm.config.ts migration:create",
    "migration:up": "mikro-orm --config api/mikro-orm.config.ts migration:up",
    "migration:down": "mikro-orm --config api/mikro-orm.config.ts migration:down"
  },
  "mikro-orm": {
    "useTsNode": true,
    "tsConfigPath": "tsconfig.json"
  },
  "dependencies": {
    "@mikro-orm/core": "^6.6.9",
    "@mikro-orm/migrations": "^6.6.9",
    "@mikro-orm/nestjs": "^6.1.2",
    "@mikro-orm/postgresql": "^6.6.9",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "nestjs-pino": "^4.6.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@munilive/tsconfig": "^1.0.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.1.17",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.18",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "unplugin-swc": "^1.5.9",
    "vite-tsconfig-paths": "^5.0.0",
    "vitest": "^4.1.0"
  }
}
