{
  "name": "todo-nodejs",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev": "pnpm --filter @todo-nodejs/server dev:api & pnpm --filter @todo-nodejs/admin dev",
    "dev:admin": "pnpm --filter @todo-nodejs/admin dev",
    "start": "pnpm --filter @todo-nodejs/server start:api",
    "test": "pnpm -r test",
    "test:coverage": "pnpm --filter @todo-nodejs/server test:coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "prettier": "@munilive/prettier-config",
  "lint-staged": {
    "*.{js,mjs,ts}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@munilive/eslint-config": "^1.0.3",
    "@munilive/prettier-config": "^1.0.3",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  }
}
